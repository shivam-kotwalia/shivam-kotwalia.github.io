---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import { site, skillGroups, aboutParagraphs } from '../config';

const entries = await getCollection('experience');
---

<BaseLayout title="About" description={`About ${site.name}`}>
  <section class="mx-auto max-w-4xl px-4 py-16 sm:px-6">
    <div class="paper animate-fade-up p-6 sm:p-10">
      <p class="inline-flex items-center gap-3 text-xs font-semibold uppercase tracking-[0.22em] text-brand-700 dark:text-brand-400">
        <span class="h-px w-8 bg-brand-500"></span>
        About
      </p>
      <h1 class="mt-5 text-4xl text-slate-900 sm:text-5xl dark:text-white">
        The story behind the <span class="italic text-brand-600 dark:text-brand-400">work</span>.
      </h1>

      <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-slate-500 dark:text-slate-400">
        <span class="inline-flex items-center gap-1.5">
          <Icon name="map-pin" class="h-4 w-4" />
          {site.location}
        </span>
      </div>

      <div class="prose prose-slate mt-8 max-w-none leading-relaxed dark:prose-invert">
        {aboutParagraphs.map((paragraph) => <p>{paragraph}</p>)}
      </div>

      <h2 class="mt-12 text-3xl text-slate-900 dark:text-white">
        Education
      </h2>
      <div class="mt-5 grid gap-4 sm:grid-cols-2">
        <article class="rounded-2xl border border-slate-200 bg-slate-50 p-4 dark:border-slate-700 dark:bg-slate-900/60">
          <p class="text-sm text-slate-500 dark:text-slate-400">2026 - 2027</p>
          <h3 class="mt-1 font-semibold text-slate-900 dark:text-white">IIM Calcutta</h3>
          <p class="text-sm text-slate-600 dark:text-slate-300">Executive MBA</p>
        </article>
        <article class="rounded-2xl border border-slate-200 bg-slate-50 p-4 dark:border-slate-700 dark:bg-slate-900/60">
          <p class="text-sm text-slate-500 dark:text-slate-400">Undergraduate</p>
          <h3 class="mt-1 font-semibold text-slate-900 dark:text-white">Bachelor of Technology</h3>
          <p class="text-sm text-slate-600 dark:text-slate-300">Electronics & Communication Engineering</p>
        </article>
      </div>

      <p class="mt-12 inline-flex items-center gap-3 text-xs font-semibold uppercase tracking-[0.22em] text-brand-700 dark:text-brand-400">
        <span class="h-px w-8 bg-brand-500"></span>
        Career
      </p>
      <h2 id="career-chapters" class="mt-3 scroll-mt-24 text-3xl text-slate-900 dark:text-white">
        Career chapters
      </h2>
      <p class="mt-3 text-slate-600 dark:text-slate-400">
        Roles across consulting, big tech, and fintech focused on growth, strategy, and applied AI.
      </p>

      <ol class="mt-8 space-y-6">
        {
          entries.map((entry) => (
            <li class="paper p-6 sm:p-7">
              <div class="flex flex-wrap items-start gap-4">
                {entry.data.companyLogo && (
                  <img
                    src={entry.data.companyLogo}
                    alt={`${entry.data.company} logo`}
                    width="48"
                    height="48"
                    loading="lazy"
                    class="h-12 w-12 rounded-xl border border-slate-200 bg-white p-1.5 object-contain dark:border-slate-700"
                  />
                )}
                <div class="min-w-0 flex-1">
                  <div class="flex flex-wrap items-baseline gap-x-2 gap-y-1">
                    <h3 class="text-xl text-slate-900 dark:text-white">
                      {entry.data.role}
                    </h3>
                    <span class="text-slate-400">·</span>
                    {entry.data.companyUrl ? (
                      <a
                        href={entry.data.companyUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center gap-1 font-medium text-brand-600 hover:underline dark:text-brand-400"
                      >
                        {entry.data.company}
                        <Icon name="arrow-up-right" class="h-3.5 w-3.5" />
                      </a>
                    ) : (
                      <span class="font-medium text-slate-700 dark:text-slate-300">
                        {entry.data.company}
                      </span>
                    )}
                  </div>

                  <div class="mt-1 flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-slate-500 dark:text-slate-400">
                    <span class="inline-flex items-center gap-1.5">
                      <Icon name="calendar" class="h-4 w-4" />
                      {entry.data.start} — {entry.data.end}
                    </span>
                    {entry.data.location && (
                      <span class="inline-flex items-center gap-1.5">
                        <Icon name="map-pin" class="h-4 w-4" />
                        {entry.data.location}
                      </span>
                    )}
                  </div>

                  <p class="mt-4 text-slate-700 dark:text-slate-300">
                    {entry.data.summary}
                  </p>

                  {entry.data.companySource && (
                    <p class="mt-2 text-xs text-slate-500 dark:text-slate-400">
                      {entry.data.companySource}
                    </p>
                  )}

                  {entry.data.highlights.length > 0 && (
                    <ul class="mt-4 list-disc space-y-1.5 pl-5 text-sm text-slate-700 marker:text-brand-500 dark:text-slate-300">
                      {entry.data.highlights.map((h) => (
                        <li>{h}</li>
                      ))}
                    </ul>
                  )}

                  {entry.data.skills.length > 0 && (
                    <div class="mt-4 flex flex-wrap gap-2">
                      {entry.data.skills.map((s) => (
                        <span class="rounded-lg bg-slate-100 px-2.5 py-1 text-xs font-medium text-slate-700 dark:bg-slate-800 dark:text-slate-300">
                          {s}
                        </span>
                      ))}
                    </div>
                  )}
                </div>
              </div>
            </li>
          ))
        }
      </ol>

      <h2 class="mt-12 text-3xl text-slate-900 dark:text-white">
        Skills
      </h2>
      <div class="mt-6 space-y-6">
        {
          skillGroups.map((group) => (
            <div>
              <h3 class="text-sm font-semibold text-slate-900 dark:text-white">
                {group.title}
              </h3>
              <div class="mt-3 flex flex-wrap gap-2">
                {group.skills.map((s) => (
                  <span class="rounded-lg bg-slate-100 px-2.5 py-1 text-xs font-medium text-slate-700 dark:bg-slate-800 dark:text-slate-300">
                    {s}
                  </span>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</BaseLayout>
