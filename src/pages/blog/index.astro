---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const dateFmt = new Intl.DateTimeFormat('en', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<BaseLayout title="Blog" description="Notes on AI, data, and engineering.">
  <section class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
    <div class="animate-fade-up">
      <h1 class="text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl dark:text-white">
        Blog
      </h1>
      <p class="mt-3 text-slate-600 dark:text-slate-400">
        Notes on AI, data, and engineering.
      </p>

      {
        posts.length === 0 ? (
          <p class="mt-10 text-slate-500 dark:text-slate-400">
            No posts yet. Check back soon.
          </p>
        ) : (
          <div class="mt-10 space-y-3">
            {posts.map((post) => (
              <a
                href={`/blog/${post.id}/`}
                class="group block rounded-2xl border border-slate-200 bg-white p-5 transition-colors hover:border-brand-300 dark:border-slate-800 dark:bg-slate-900/50 dark:hover:border-brand-700"
              >
                <time class="text-xs text-slate-500 dark:text-slate-400">
                  {dateFmt.format(post.data.pubDate)}
                </time>
                <h2 class="mt-1 text-lg font-semibold text-slate-900 group-hover:text-brand-600 dark:text-white dark:group-hover:text-brand-400">
                  {post.data.title}
                </h2>
                <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">
                  {post.data.description}
                </p>
                {post.data.tags.length > 0 && (
                  <div class="mt-3 flex flex-wrap gap-2">
                    {post.data.tags.map((t) => (
                      <span class="rounded-md bg-slate-100 px-2 py-0.5 text-xs font-medium text-slate-600 dark:bg-slate-800 dark:text-slate-400">
                        #{t}
                      </span>
                    ))}
                  </div>
                )}
              </a>
            ))}
          </div>
        )
      }
    </div>
  </section>
</BaseLayout>
