const isStroke = strokeIcons.includes(name);
---

<svg
  class={className}
  viewBox="0 0 24 24"
  fill={isStroke ? 'none' : 'currentColor'}
  stroke={isStroke ? 'currentColor' : 'none'}
  stroke-width={isStroke ? 2 : undefined}
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
>
  <path d={paths[name]} />
</svg>
